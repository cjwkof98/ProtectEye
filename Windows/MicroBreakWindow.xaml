<Window x:Class="ProtectEye.Windows.MicroBreakWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="微休息" Height="140" Width="660"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize" ShowActivated="False"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                    <ThicknessAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Margin" From="0,-20,0,0" To="0,0,0,0" Duration="0:0:0.5" >
                        <ThicknessAnimation.EasingFunction>
                            <QuinticEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    
    <Grid x:Name="RootGrid" Margin="12" Opacity="0">
        <!-- 阴影隔离层：专门渲染阴影，不含边框 -->
        <Border CornerRadius="0" Background="{DynamicResource Theme.CardBg}" SnapsToDevicePixels="False">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" Direction="270" ShadowDepth="4" Color="Black" Opacity="0.45"/>
            </Border.Effect>
        </Border>

        <!-- 内容层：专门渲染边框和内容，不含阴影 -->
        <Border x:Name="MainBorder" Background="{DynamicResource Theme.CardBg}" Opacity="0.96" 
                CornerRadius="0" Padding="30,15" 
                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" 
                RenderOptions.BitmapScalingMode="HighQuality"
                SnapsToDevicePixels="False">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- 图标 -->
                <Viewbox Grid.Column="0" Width="40" Height="40" Margin="0,0,20,0" VerticalAlignment="Center">
                    <Canvas Width="24" Height="24">
                        <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 21.5C5.37 21.5 1.5 14.93 1.5 12s3.87-9.5 10.5-9.5 10.5 6.57 10.5 9.5-3.87 9.5-10.5 9.5z"/>
                        <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 16.5a4.5 4.5 0 100-9 4.5 4.5 0 000 9z M12 14a2 2 0 100-4 2 2 0 000 4z"/>
                    </Canvas>
                </Viewbox>
                <!-- 文本 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="20-20-20 视力微休整" Foreground="{DynamicResource Theme.TextBase}" FontSize="22" FontWeight="SemiBold" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                    <TextBlock x:Name="TxtTip" Text="请将视线从屏幕移开，眺望远处" Foreground="{DynamicResource Theme.TextMuted}" FontSize="18" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <!-- 倒计时与跳过 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Border Background="{DynamicResource Theme.ControlBg}" CornerRadius="0" Width="60" Height="42" Margin="0,0,12,0">
                        <TextBlock x:Name="TxtSeconds" Text="20" Foreground="{DynamicResource Theme.Primary}" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Button Content="✕" ToolTip="关闭本轮微休息" Foreground="{DynamicResource Theme.TextDesc}" Background="Transparent" BorderThickness="0" FontSize="20" Padding="10,0" Cursor="Hand" Click="BtnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="0"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
