<Window x:Class="ProtectEye.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProtectEye"
        Title="护眼卫士 · ProtectEye" SizeToContent="Height" MinHeight="540" Width="540"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Theme.Bg}"
        Icon="pack://application:,,,/app.ico">

    <Window.Resources>
        <!-- ===== 基础样式 ===== -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/> <!-- 更亮的白色标签 -->
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        </Style>
        <Style x:Key="ValueBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Theme.ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}"/> <!-- 更高对比边框 -->
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Theme.Primary}"/> <!-- 霓虹 Teal -->
        </Style>
        <Style x:Key="UnitStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMuted}"/> <!-- 次要文字提亮 -->
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
        <Style x:Key="Sep" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Theme.Sep}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,14,0,14"/>
        </Style>

        <!-- ===== ComboBox 深色模板 ===== -->
        <Style x:Key="DarkComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{DynamicResource Theme.ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{DynamicResource Theme.ControlBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <ContentPresenter x:Name="contentSite"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="9,0,32,0"
                                                                  TextElement.Foreground="{DynamicResource Theme.TextBase}" TextElement.FontFamily="Segoe UI, Microsoft YaHei UI" TextElement.FontSize="13" IsHitTestVisible="False"/>
                                                <Path HorizontalAlignment="Right" Margin="0,0,12,0" Data="M0,0 L6,5 L12,0" Stroke="{DynamicResource Theme.TextMuted}" StrokeThickness="1.5" VerticalAlignment="Center" Fill="Transparent"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Border.BorderBrush" TargetName="contentSite" Value="{DynamicResource Theme.Primary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border MinWidth="{TemplateBinding ActualWidth}" MaxHeight="220" Background="{DynamicResource Theme.ControlBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" CornerRadius="6" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="6" Color="Black" Opacity="0.8"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
                        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="12,9"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="4,2">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Theme.Sep}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Theme.Primary}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Theme.Bg}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 按钮样式 ===== -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Theme.Primary}"/> <!-- 闪亮 Teal -->
            <Setter Property="Foreground" Value="{DynamicResource Theme.Bg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource Theme.Primary}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="{DynamicResource Theme.PrimaryDark}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Theme.ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Theme.Sep}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SmallIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMuted}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Theme.Sep}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SmallChartBtn" TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Tab ===== -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextDesc}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0,8,26,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <StackPanel>
                            <ContentPresenter x:Name="Ct" ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              Margin="{TemplateBinding Padding}"/>
                            <Border x:Name="Ind" Height="3" Background="Transparent" CornerRadius="1.5" Margin="0,3,26,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Ct" Property="TextElement.Foreground" Value="{DynamicResource Theme.TextBase}"/>
                                <Setter TargetName="Ind" Property="Background" Value="{DynamicResource Theme.Primary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ct" Property="TextElement.Foreground" Value="{DynamicResource Theme.TextBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="26,20,26,22">
        <StackPanel>
            <!-- ── Header ── -->
            <Grid Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="26" Height="26" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <!-- Iconsax Eye (Linear) -->
                            <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 21.5C5.37 21.5 1.5 14.93 1.5 12s3.87-9.5 10.5-9.5 10.5 6.57 10.5 9.5-3.87 9.5-10.5 9.5z"/>
                            <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 16.5a4.5 4.5 0 100-9 4.5 4.5 0 000 9z M12 14a2 2 0 100-4 2 2 0 000 4z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="护眼卫士" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Theme.TextBase}"
                               FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center"/>
                    <TextBlock Text="ProtectEye" FontSize="13" Foreground="{DynamicResource Theme.TextDesc}"
                               FontFamily="Segoe UI" VerticalAlignment="Bottom" Margin="8,0,0,3"/>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                           Text="{x:Static local:AppVersion.Version}"
                           FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI" FontWeight="SemiBold"/>
            </Grid>

            <!-- ── Tab Bar ── -->
            <TabControl x:Name="MainTab" HorizontalAlignment="Left" SelectionChanged="MainTab_SelectionChanged">
                <TabItem Header="首页"/>
                <TabItem Header="用眼分析"/>
                <TabItem Header="设置管理"/>
            </TabControl>
            <Border Background="{DynamicResource Theme.Sep}" Height="1" Margin="0,0,0,24"/>

            <!-- ══════════════════════════════════════════════════════
                 首页面板
            ══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="PanelHome">
                <!-- 今日统计卡片 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="今日工作" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,5"/>
                            <TextBlock x:Name="HomeTxtWork" Text="—" FontSize="28" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="今日休息" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,5"/>
                            <TextBlock x:Name="HomeTxtRest" Text="—" FontSize="28" Foreground="{DynamicResource Theme.Primary}" FontFamily="Segoe UI Light, Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="休息次数" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,5"/>
                            <TextBlock x:Name="HomeTxtRestCnt" Text="—" FontSize="28" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="跳过次数" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,5"/>
                            <TextBlock x:Name="HomeTxtSkip" Text="—" FontSize="28" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI Light, Segoe UI"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 当前配置速览 -->
                <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="20,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="智能监测中" FontSize="14" Foreground="{DynamicResource Theme.TextBase}"
                                   FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="工作周期" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock x:Name="HomeCfgWork" Text="45" FontSize="24" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                                    <TextBlock Text=" 分" FontSize="13" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="休息时长" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock x:Name="HomeCfgRest" Text="5" FontSize="24" Foreground="{DynamicResource Theme.Primary}" FontFamily="Segoe UI Light, Segoe UI"/>
                                    <TextBlock Text=" 分" FontSize="13" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="提前预警" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock x:Name="HomeCfgWarn" Text="5" FontSize="24" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                                    <TextBlock Text=" 分" FontSize="13" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="空闲重置" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock x:Name="HomeCfgIdle" Text="5" FontSize="24" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                                    <TextBlock Text=" 分" FontSize="13" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource Theme.Sep}" Height="1" Margin="0,16,0,16"/>

                        <!-- 功能状态标签 -->
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Border x:Name="TagDnd" CornerRadius="6" Padding="12,6" Margin="0,0,10,0" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="DotDnd" Width="6" Height="6" Fill="{DynamicResource Theme.Primary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TagDndText" Text="免打扰" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="TagStartup" CornerRadius="6" Padding="12,6" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="DotStartup" Width="6" Height="6" Fill="{DynamicResource Theme.TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TagStartupText" Text="开机启动" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 底部操作按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource GhostBtn}" Click="BtnRestNow_Click">
                        <StackPanel Orientation="Horizontal">
                            <!-- Iconsax Coffee (Linear) -->
                            <Path Data="M11 2v4M15 2v4M7 2v4M22 10.5V13c0 1.66-1.34 3-3 3h-.5M2 10h16v5.5C18 18.54 15.54 21 12.5 21h-5C4.46 21 2 18.54 2 15.5V10z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="立即休息" VerticalAlignment="Center" Margin="0,0,2,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- ══════════════════════════════════════════════════════
                 用眼分析面板
            ══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="PanelLog" Visibility="Collapsed">
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="今日工作" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtTotalWork" Text="—" FontSize="26" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="今日休息" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtTotalRest" Text="—" FontSize="26" Foreground="{DynamicResource Theme.Primary}" FontFamily="Segoe UI Light, Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="休息次数" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtRestCount" Text="—" FontSize="26" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="深度专注(>1h)" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtSkipCount" Text="—" FontSize="26" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI Light, Segoe UI"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 图表 -->
                <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="趋势分析" FontSize="14" Foreground="{DynamicResource Theme.TextBase}"
                                       FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center"/>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button x:Name="BtnToday" Content="今日占比" Style="{StaticResource SmallChartBtn}"
                                        Background="{DynamicResource Theme.Primary}" Foreground="Black" FontWeight="SemiBold" Click="BtnChartToday_Click"/>
                                <Button x:Name="BtnWeek" Content="本周趋势" Style="{StaticResource SmallChartBtn}"
                                        Background="{DynamicResource Theme.ControlBg}" Foreground="{DynamicResource Theme.TextMuted}" Click="BtnChartWeek_Click" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Rectangle Width="10" Height="10" Fill="{DynamicResource Theme.Border}" RadiusX="3" RadiusY="3" VerticalAlignment="Center"/>
                            <TextBlock Text="工作时长" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="6,0,18,0" VerticalAlignment="Center"/>
                            <Rectangle Width="10" Height="10" Fill="{DynamicResource Theme.Primary}" RadiusX="3" RadiusY="3" VerticalAlignment="Center"/>
                            <TextBlock Text="休息时长" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Canvas x:Name="ChartCanvas" Height="130" Background="Transparent"/>
                        <Canvas x:Name="ChartXAxis" Height="22" Background="Transparent" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 日志工具栏 -->
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="运行记录" FontSize="14" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SmallIconBtn}" Click="BtnRefresh_Click" Margin="0,0,4,0" ToolTip="刷新日志">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M22 12c0 5.52-4.48 10-10 10S2 17.52 2 12 6.48 2 12 2c2.4 0 4.6.85 6.32 2.27L20 6h-5.5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                <TextBlock Text="刷新" FontWeight="Medium"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SmallIconBtn}" Click="BtnOpenLogFolder_Click" Margin="0,0,4,0" ToolTip="打开日志文件夹">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2 10.5h20M2 6.5A2.5 2.5 0 014.5 4h5l1.9 2H19.5A2.5 2.5 0 0122 8.5v11.5M2 8.5v11.5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="Transparent" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                <TextBlock Text="目录" FontWeight="Medium"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SmallIconBtn}" Click="BtnClear_Click" ToolTip="清空所有记录">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M21 5.98c-3.33-.33-6.68-.5-10.02-.5-1.98 0-3.96.1-5.94.3L3 5.98M8.5 5.97L8.72 4.66c.16-1.03.26-1.66 1.87-1.66h2.82c1.61 0 1.71.63 1.87 1.66l.22 1.31M18.85 9.14l-.65 10.07A3.33 3.33 0 0114.87 22H9.13A3.33 3.33 0 015.8 19.21l-.65-10.07M10.33 16.5h3.33M9.5 12.5h5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="Transparent" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                <TextBlock Text="清空" FontWeight="Medium"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="8" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Height="165">
                    <ScrollViewer x:Name="ScrollLog" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LogList" Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='MM-dd HH:mm:ss'}"
                                                   Foreground="{DynamicResource Theme.TextDesc}" FontSize="12" FontFamily="Consolas"
                                                   Margin="16,8,0,8" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding EventTypeText}"
                                                   Foreground="{DynamicResource Theme.TextMuted}" FontSize="12"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Note}"
                                                   Foreground="{DynamicResource Theme.TextBase}" FontSize="12"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- ══════════════════════════════════════════════════════
                 设置面板
            ══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="PanelSettings" Visibility="Collapsed">
                <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <!-- 时间配置 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM12 7v5l3 3"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="专注与休息规则" FontSize="14" Foreground="{DynamicResource Theme.TextBase}"
                                       FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="45"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="工作周期" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="InpWorkInterval" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                            <TextBlock Grid.Column="2" Text="分钟" Style="{StaticResource UnitStyle}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="45"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="休息时长" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="InpRestDuration" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                            <TextBlock Grid.Column="2" Text="分钟" Style="{StaticResource UnitStyle}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="45"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="提前预警" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="InpWarningDuration" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                            <TextBlock Grid.Column="2" Text="分钟" Style="{StaticResource UnitStyle}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="45"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="空闲自动重置" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="InpIdle" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                            <TextBlock Grid.Column="2" Text="分钟" Style="{StaticResource UnitStyle}"/>
                        </Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="45"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="日志保留期限" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="InpMaxLogDays" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                            <TextBlock Grid.Column="2" Text="天" Style="{StaticResource UnitStyle}"/>
                        </Grid>
                        <Border Style="{StaticResource Sep}"/>

                        <!-- 功能开关 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M10 22L14 2 12 11h8l-10 11 2-9H4l6-9z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="系统增强" FontSize="14" Foreground="{DynamicResource Theme.TextBase}"
                                       FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="智能免打扰" Style="{StaticResource LabelStyle}"/>
                            <CheckBox x:Name="ChkDnd" Grid.Column="1" Content="运行全屏应用或视频时推迟休息"
                                      VerticalAlignment="Center" Foreground="{DynamicResource Theme.TextBase}" FontSize="13"
                                      FontFamily="Segoe UI, Microsoft YaHei UI"/>
                        </Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="微休息提示" Style="{StaticResource LabelStyle}" ToolTip="20-20-20法则：每20分钟提醒远视20秒"/>
                            <CheckBox x:Name="ChkMicroBreak" Grid.Column="1" Content="开启 20-20-20 眼保放松悬浮窗"
                                      VerticalAlignment="Center" Foreground="{DynamicResource Theme.TextBase}" FontSize="13"
                                      FontFamily="Segoe UI, Microsoft YaHei UI"/>
                        </Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="健康科普" Style="{StaticResource LabelStyle}"/>
                            <CheckBox x:Name="ChkHealthTips" Grid.Column="1" Content="在强制休息界面显示医学护眼贴士"
                                      VerticalAlignment="Center" Foreground="{DynamicResource Theme.TextBase}" FontSize="13"
                                      FontFamily="Segoe UI, Microsoft YaHei UI"/>
                        </Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="开机自启" Style="{StaticResource LabelStyle}"/>
                            <CheckBox x:Name="ChkStartup" Grid.Column="1" Content="随 Windows 系统启动"
                                      VerticalAlignment="Center" Foreground="{DynamicResource Theme.TextBase}" FontSize="13"
                                      FontFamily="Segoe UI, Microsoft YaHei UI"/>
                        </Grid>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="立即休息快捷键" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="InpShortcut" Grid.Column="1" Style="{StaticResource ValueBoxStyle}" MaxWidth="150" HorizontalAlignment="Left" ToolTip="例如 Ctrl+Alt+R"/>
                        </Grid>
                        <Border Style="{StaticResource Sep}"/>

                        <!-- 视觉风格 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 2A10 10 0 1022 12c0-1.83-1.63-3.13-3.14-2.88A6 6 0 1112 2v0"/>
                                    <Path Fill="{DynamicResource Theme.Primary}" Data="M8 9a1 1 0 11-2 0 1 1 0 012 0z M11 6a1 1 0 11-2 0 1 1 0 012 0z M16 6a1 1 0 11-2 0 1 1 0 012 0z M19 9a1 1 0 11-2 0 1 1 0 012 0z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="沉浸式休息界面" FontSize="14" Foreground="{DynamicResource Theme.TextBase}"
                                       FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI"/>
                        </StackPanel>
                        <ComboBox x:Name="CmbBgStyle" Style="{StaticResource DarkComboStyle}">
                            <ComboBoxItem Content="极限护眼模式（纯色遮罩）"/>
                            <ComboBoxItem Content="轻度毛玻璃（半透明遮罩）"/>
                            <ComboBoxItem Content="桌面毛玻璃（截取桌面背景虚化）"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,16">
                            <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 4V20M4 12H20M12 4C16.4183 4 20 7.58172 20 12M12 4C7.58172 4 4 7.58172 4 12M20 12C20 16.4183 16.4183 20 12 20M4 12C4 16.4183 7.58172 20 12 20"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="全局色彩主题" FontSize="14" Foreground="{DynamicResource Theme.TextBase}"
                                       FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI"/>
                        </StackPanel>
                        <ComboBox x:Name="CmbAppTheme" Style="{StaticResource DarkComboStyle}">
                            <ComboBoxItem Content="暗夜极客黑 (黑/青)"/>
                            <ComboBoxItem Content="冷翡高级灰 (深灰/蓝)"/>
                            <ComboBoxItem Content="活力暖阳橙 (黄/橙)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtSaveSuccess" Text="✓ 保存成功" Foreground="{DynamicResource Theme.Primary}" FontWeight="SemiBold" FontSize="13" 
                               FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center" Margin="0,0,16,0" Visibility="Collapsed"/>
                    <Button Style="{StaticResource GhostBtn}" Margin="0,0,10,0" Click="BtnRestNow_Click">
                        <StackPanel Orientation="Horizontal">
                            <!-- Iconsax Coffee (Linear) -->
                            <Path Data="M11 2v4M15 2v4M7 2v4M22 10.5V13c0 1.66-1.34 3-3 3h-.5M2 10h16v5.5C18 18.54 15.54 21 12.5 21h-5C4.46 21 2 18.54 2 15.5V10z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="立即休息" VerticalAlignment="Center" Margin="0,0,2,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryBtn}" Click="BtnSave_Click">
                        <StackPanel Orientation="Horizontal">
                            <!-- Iconsax Tick Square (Linear) -->
                            <Path Data="M9 22h6c5 0 7-2 7-7V9c0-5-2-7-7-7H9C4 2 2 4 2 9v6c0 5 2 7 7 7z M7.75 12l2.83 2.83 5.67-5.66"
                                  Stroke="Black" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="Transparent" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="保存配置" VerticalAlignment="Center" Margin="0,0,2,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
