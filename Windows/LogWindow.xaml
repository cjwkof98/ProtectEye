<Window x:Class="ProtectEye.Windows.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="运行日志 · ProtectEye"
        Width="660" Height="560"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Background="#0F0F0F">

    <Window.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="FontFamily" Value="Segoe UI Light, Segoe UI"/>
            <Setter Property="FontWeight" Value="Light"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#242424"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="运行日志" FontSize="20" FontWeight="Bold"
                       Foreground="#F3F4F6" FontFamily="Segoe UI Semibold, Segoe UI"/>
            <TextBlock x:Name="TxtDateRange" Text="今日记录" FontSize="12"
                       Foreground="#4B5563" FontFamily="Segoe UI" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 今日统计卡片 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="今日工作" Style="{StaticResource StatLabel}"/>
                    <TextBlock x:Name="TxtTotalWork" Text="—" Style="{StaticResource StatValue}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="今日休息" Style="{StaticResource StatLabel}"/>
                    <TextBlock x:Name="TxtTotalRest" Text="—" Style="{StaticResource StatValue}" Foreground="#0D9488"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="休息次数" Style="{StaticResource StatLabel}"/>
                    <TextBlock x:Name="TxtRestCount" Text="—" Style="{StaticResource StatValue}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="跳过次数" Style="{StaticResource StatLabel}"/>
                    <TextBlock x:Name="TxtSkipCount" Text="—" Style="{StaticResource StatValue}" Foreground="#6B7280"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="详细记录" FontSize="11" Foreground="#4B5563"
                       FontFamily="Segoe UI Semibold, Segoe UI" VerticalAlignment="Center" Margin="0,0,0,0"/>
            <Rectangle Width="1" Fill="#2D2D2D" Margin="12,2"/>
            <Button Content="刷新" Style="{StaticResource ActionBtn}" Click="BtnRefresh_Click" Margin="0,0,6,0"/>
            <Button Content="清空日志" Style="{StaticResource ActionBtn}" Click="BtnClear_Click"/>
        </StackPanel>

        <!-- 日志列表 -->
        <Border Grid.Row="3" Background="#0A0A0A" CornerRadius="8" BorderBrush="#1E1E1E" BorderThickness="1">
            <ScrollViewer x:Name="ScrollLog" VerticalScrollBarVisibility="Auto" Padding="0">
                <ItemsControl x:Name="LogList" Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="RowBg" Background="Transparent" Grid.ColumnSpan="3"/>
                                <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='MM-dd HH:mm:ss'}"
                                           Foreground="#374151" FontSize="12" FontFamily="Consolas, Courier New"
                                           Margin="16,9,0,9" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding EventTypeText}"
                                           x:Name="EventText"
                                           Foreground="#6B7280" FontSize="12" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Note}"
                                           Foreground="#4B5563" FontSize="12" FontFamily="Segoe UI"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           Margin="0,0,16,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="TextElement.Foreground" Value="#9CA3AF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 底部状态栏 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Right">
            <TextBlock x:Name="TxtLogCount" Text="" FontSize="11" Foreground="#374151"
                       FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="关闭" Style="{StaticResource ActionBtn}" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
