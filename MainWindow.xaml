<Window x:Class="ProtectEye.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProtectEye"
        Title="护眼卫士 · ProtectEye" MinWidth="820" MinHeight="500" Width="820" Height="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Theme.Bg}"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Icon="pack://application:,,,/app.ico">

    <Window.Resources>
        <!-- ===== 基础样式 ===== -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/> <!-- 更亮的白色标签 -->
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        </Style>
        <Style x:Key="ValueBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Theme.ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}"/> <!-- 更高对比边框 -->
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Theme.Primary}"/> <!-- 霓虹 Teal -->
        </Style>
        <Style x:Key="UnitStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMuted}"/> <!-- 次要文字提亮 -->
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
        <Style x:Key="Sep" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Theme.Sep}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,14,0,14"/>
        </Style>

        <!-- ===== ComboBox 深色模板 ===== -->
        <Style x:Key="DarkComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{DynamicResource Theme.ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{DynamicResource Theme.ControlBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <ContentPresenter x:Name="contentSite"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="9,0,32,0"
                                                                  TextElement.Foreground="{DynamicResource Theme.TextBase}" TextElement.FontFamily="Segoe UI, Microsoft YaHei UI" TextElement.FontSize="13" IsHitTestVisible="False"/>
                                                <Path HorizontalAlignment="Right" Margin="0,0,12,0" Data="M0,0 L6,5 L12,0" Stroke="{DynamicResource Theme.TextMuted}" StrokeThickness="1.5" VerticalAlignment="Center" Fill="Transparent"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Border.BorderBrush" TargetName="contentSite" Value="{DynamicResource Theme.Primary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border MinWidth="{TemplateBinding ActualWidth}" MaxHeight="220" Background="{DynamicResource Theme.ControlBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" CornerRadius="6" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="6" Color="Black" Opacity="0.8"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
                        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="12,9"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="4,2">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Theme.Sep}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Theme.Primary}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Theme.Bg}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 按钮样式 ===== -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Theme.Primary}"/> <!-- 闪亮 Teal -->
            <Setter Property="Foreground" Value="{DynamicResource Theme.Bg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource Theme.PrimaryLight}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="{DynamicResource Theme.PrimaryDark}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Theme.ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Theme.Sep}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 暂停按钮（悬停变红警示） ===== -->
        <Style x:Key="PauseDangerBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3B0D0D"/>
                    <Setter Property="BorderBrush" Value="#EF4444"/>
                    <Setter Property="Foreground" Value="#EF4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SmallIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMuted}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Theme.Sep}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SmallChartBtn" TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Tab ===== -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextDesc}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0,8,26,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <StackPanel>
                            <ContentPresenter x:Name="Ct" ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              Margin="{TemplateBinding Padding}"/>
                            <Border x:Name="Ind" Height="3" Background="Transparent" CornerRadius="1.5" Margin="0,3,26,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Ct" Property="TextElement.Foreground" Value="{DynamicResource Theme.TextBase}"/>
                                <Setter TargetName="Ind" Property="Background" Value="{DynamicResource Theme.Primary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ct" Property="TextElement.Foreground" Value="{DynamicResource Theme.TextBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource Theme.PanelBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,0,1,0" Padding="16,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,32">
                    <Viewbox Width="26" Height="26" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <!-- Iconsax Eye (Linear) -->
                            <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 21.5C5.37 21.5 1.5 14.93 1.5 12s3.87-9.5 10.5-9.5 10.5 6.57 10.5 9.5-3.87 9.5-10.5 9.5z"/>
                            <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 16.5a4.5 4.5 0 100-9 4.5 4.5 0 000 9z M12 14a2 2 0 100-4 2 2 0 000 4z"/>
                        </Canvas>
                    </Viewbox>
                    <StackPanel>
                        <TextBlock Text="护眼卫士" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI"/>
                        <TextBlock Text="ProtectEye" FontSize="11" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>

                <!-- TabMenu -->
                <ListBox Grid.Row="1" x:Name="MainTab" Background="Transparent" BorderThickness="0" SelectionChanged="MainTab_SelectionChanged" SelectedIndex="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource Theme.TextDesc}"/>
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="FontFamily" Value="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Theme.Primary}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource Theme.Bg}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Theme.Sep}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="首页"/>
                    <ListBoxItem Content="用眼分析"/>
                    <ListBoxItem Content="运行记录"/>
                    <ListBoxItem Content="设置管理"/>
                    <ListBoxItem Content="关于程序"/>
                </ListBox>

                <TextBlock Grid.Row="2" Text="{x:Static local:AppVersion.Version}" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border Grid.Column="1" Padding="24,18,24,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- ══════════════════════════════════════════════════════
                         首页面板
                    ══════════════════════════════════════════════════════ -->
                    <StackPanel x:Name="PanelHome">
                        <!-- 首页统计卡 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="今日工作" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="HomeTxtWork" Text="—" FontSize="24" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="今日休息" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="HomeTxtRest" Text="—" FontSize="24" Foreground="{DynamicResource Theme.Primary}" FontFamily="Segoe UI Light, Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="休息次数" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="HomeTxtRestCnt" Text="—" FontSize="24" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="6" Background="{DynamicResource Theme.PanelBg}" CornerRadius="10" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="跳过次数" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="HomeTxtSkip" Text="—" FontSize="24" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI Light, Segoe UI"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 状态与配置 -->
                        <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="20,10" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock x:Name="TxtProtectStatus" Text="您的眼睛正在被保护" FontSize="16" Foreground="{DynamicResource Theme.Primary}"
                                               FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center"/>
                                    <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Width="16" Height="16" Margin="0,0,8,0">
                                        <Ellipse x:Name="StatusDot" Fill="{DynamicResource Theme.Primary}" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse x:Name="StatusRing" Stroke="{DynamicResource Theme.Primary}" StrokeThickness="2" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" From="0.5" To="3.5" Duration="0:0:1.5"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" From="0.5" To="3.5" Duration="0:0:1.5"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:1.5"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                            <Ellipse.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1" CenterX="8" CenterY="8"/>
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                    </Grid>
                                </Grid>
                                
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="距下次微休息 (20-20-20)" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <TextBlock x:Name="TxtNextMicro" Text="—:—" FontSize="26" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="距下次深度休息" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <TextBlock x:Name="TxtNextMacro" Text="—:—" FontSize="26" Foreground="{DynamicResource Theme.Primary}" FontFamily="Segoe UI Light, Segoe UI" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Border Background="{DynamicResource Theme.Sep}" Height="1" Margin="0,0,0,12"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="工作周期" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock x:Name="HomeCfgWork" Text="45" FontSize="18" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                                            <TextBlock Text=" 分" FontSize="11" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="休息时长" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock x:Name="HomeCfgRest" Text="5" FontSize="18" Foreground="{DynamicResource Theme.Primary}" FontFamily="Segoe UI Light, Segoe UI"/>
                                            <TextBlock Text=" 分" FontSize="11" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="提前预警" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock x:Name="HomeCfgWarn" Text="5" FontSize="18" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                                            <TextBlock Text=" 分" FontSize="11" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="空闲重置" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock x:Name="HomeCfgIdle" Text="5" FontSize="18" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                                            <TextBlock Text=" 分" FontSize="11" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <Border Background="{DynamicResource Theme.Sep}" Height="1" Margin="0,12,0,12"/>

                                <!-- 功能状态标签 -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <Border x:Name="TagDnd" CornerRadius="6" Padding="12,6" Margin="0,0,10,0" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="DotDnd" Width="6" Height="6" Fill="{DynamicResource Theme.Primary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TagDndText" Text="免打扰" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="TagStartup" CornerRadius="6" Padding="12,6" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="DotStartup" Width="6" Height="6" Fill="{DynamicResource Theme.TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TagStartupText" Text="开机启动" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 底部操作按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                            <Button x:Name="BtnTogglePause" Style="{StaticResource PauseDangerBtn}" Padding="20,12" FontSize="14" Click="BtnTogglePause_Click" Margin="0,0,12,0" ToolTip="暂停后将停止所有护眼提醒，请谨慎使用">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="IconPause" Data="M6 4h4v16H6z M14 4h4v16h-4z"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TxtBtnPause" Text="暂停保护" VerticalAlignment="Center" Margin="0,0,2,0" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryBtn}" Padding="24,12" FontSize="14" Click="BtnRestNow_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M11 2v4M15 2v4M7 2v4M22 10.5V13c0 1.66-1.34 3-3 3h-.5M2 10h16v5.5C18 18.54 15.54 21 12.5 21h-5C4.46 21 2 18.54 2 15.5V10z"
                                          Stroke="{DynamicResource Theme.Bg}" StrokeThickness="1.5" Fill="Transparent" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="立即休息" VerticalAlignment="Center" Margin="0,0,2,0" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- ══════════════════════════════════════════════════════
                         用眼分析面板
                    ══════════════════════════════════════════════════════ -->
                    <StackPanel x:Name="PanelLog" Visibility="Collapsed">
                        <!-- 统计卡片 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource Theme.PanelBg}" CornerRadius="8" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="12,8">
                                <StackPanel>
                                    <TextBlock Text="本周工作" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtWeekWork" Text="—" FontSize="22" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Light, Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource Theme.PanelBg}" CornerRadius="8" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="12,8">
                                <StackPanel>
                                    <TextBlock Text="上周工作" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtLastWeekWork" Text="—" FontSize="22" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI Light, Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Background="{DynamicResource Theme.PanelBg}" CornerRadius="8" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="12,8">
                                <StackPanel>
                                    <TextBlock Text="本周休息" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtWeekRest" Text="—" FontSize="22" Foreground="{DynamicResource Theme.Primary}" FontFamily="Segoe UI Light, Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="6" Background="{DynamicResource Theme.PanelBg}" CornerRadius="8" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="12,8">
                                <StackPanel>
                                    <TextBlock Text="上周休息" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtLastWeekRest" Text="—" FontSize="22" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI Light, Segoe UI"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 图表 -->
                        <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="双周趋势对比" FontSize="13" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Rectangle Width="12" Height="4" Fill="{DynamicResource Theme.Primary}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                                        <TextBlock Text="本周" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="5,0,10,0" VerticalAlignment="Center"/>
                                        <Line X1="0" Y1="0" X2="14" Y2="0" Stroke="{DynamicResource Theme.Border}" StrokeThickness="2.5" StrokeDashArray="2 2" VerticalAlignment="Center"/>
                                        <TextBlock Text="上周" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <Button x:Name="BtnChartWork" Content="工作" Style="{StaticResource SmallChartBtn}"
                                                Background="{DynamicResource Theme.Primary}" Foreground="Black" FontWeight="SemiBold" Click="BtnChartWork_Click"/>
                                        <Button x:Name="BtnChartRest" Content="休息" Style="{StaticResource SmallChartBtn}"
                                                Background="{DynamicResource Theme.ControlBg}" Foreground="{DynamicResource Theme.TextMuted}" Click="BtnChartRest_Click" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <Canvas x:Name="ChartCanvas" Height="90" Background="Transparent"/>
                                <Canvas x:Name="ChartXAxis" Height="20" Background="Transparent"/>
                            </StackPanel>
                        </Border>

                        <!-- 视疲劳 (DES) 评估 -->
                        <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="基于 CVS/DES 模型的视疲劳评估 (本周)" FontSize="13" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center"/>
                                    <Button Style="{StaticResource GhostBtn}" Padding="4,2" Margin="6,0,0,0" ToolTip="什么是 CVS/DES 模型？" Click="BtnCvsInfo_Click">
                                        <TextBlock Text="❓" FontSize="11" Foreground="{DynamicResource Theme.Primary}" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- 分数圆角块 -->
                                    <Border Grid.Column="0" Background="{DynamicResource Theme.Sep}" CornerRadius="8" Padding="12,8" Margin="0,0,14,0" VerticalAlignment="Center" MinWidth="86">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtHealthScore" Text="—" FontSize="28" Foreground="{DynamicResource Theme.Primary}" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                            <TextBlock Text="健康指数" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- 文本评估 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtHealthStatus" Text="暂无数据" FontSize="14" Foreground="{DynamicResource Theme.TextMuted}" FontWeight="SemiBold" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,0,0,3"/>
                                        <TextBlock x:Name="TxtHealthAdvice" Text="本周尚无足够的数据进行用眼健康评估。" FontSize="12" Foreground="{DynamicResource Theme.TextDesc}" FontFamily="Segoe UI, Microsoft YaHei UI" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    
                                    <!-- 指标 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="14,0,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="连续超1小时：" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" Width="100"/>
                                            <TextBlock x:Name="TxtOver1Hour" Text="0 次" FontSize="12" Foreground="{DynamicResource Theme.TextBase}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="无视预警跳过：" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" Width="100"/>
                                            <TextBlock x:Name="TxtSkipCount" Text="0 次" FontSize="12" Foreground="{DynamicResource Theme.TextBase}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>


                    </StackPanel>

                    <!-- ══════════════════════════════════════════════════════
                         运行记录面板
                    ══════════════════════════════════════════════════════ -->
                    <StackPanel x:Name="PanelRunLog" Visibility="Collapsed">
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="系统运行详细记录" FontSize="16" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource GhostBtn}" Click="BtnRefresh_Click" Margin="0,0,8,0" Padding="12,6" ToolTip="刷新日志">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M22 12c0 5.52-4.48 10-10 10S2 17.52 2 12 6.48 2 12 2c2.4 0 4.6.85 6.32 2.27L20 6h-5.5"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="刷新记录" FontWeight="Medium"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostBtn}" Click="BtnOpenLogFolder_Click" Margin="0,0,8,0" Padding="12,6" ToolTip="打开日志文件夹">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M2 10.5h20M2 6.5A2.5 2.5 0 014.5 4h5l1.9 2H19.5A2.5 2.5 0 0122 8.5v11.5M2 8.5v11.5"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="Transparent" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="目录" FontWeight="Medium"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostBtn}" Click="BtnClear_Click" Padding="12,6" ToolTip="清空所有记录">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M21 5.98c-3.33-.33-6.68-.5-10.02-.5-1.98 0-3.96.1-5.94.3L3 5.98M8.5 5.97L8.72 4.66c.16-1.03.26-1.66 1.87-1.66h2.82c1.61 0 1.71.63 1.87 1.66l.22 1.31M18.85 9.14l-.65 10.07A3.33 3.33 0 0114.87 22H9.13A3.33 3.33 0 015.8 19.21l-.65-10.07M10.33 16.5h3.33M9.5 12.5h5"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" StrokeLineJoin="Round" Fill="Transparent" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="清空" FontWeight="Medium"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="0,8">
                            <ScrollViewer x:Name="ScrollLog" VerticalScrollBarVisibility="Auto" Padding="8,0" MaxHeight="360">
                                <ItemsControl x:Name="LogList" Focusable="False">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource Theme.Sep}" BorderThickness="0,0,0,1" Padding="16,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='MM-dd HH:mm:ss'}"
                                                               Foreground="{DynamicResource Theme.TextDesc}" FontSize="13" FontFamily="Consolas"
                                                               VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Path Data="{Binding IconPathData}" Fill="{Binding IconColorHex}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding EventTypeText}"
                                                                   Foreground="{Binding IconColorHex}" FontSize="13" FontWeight="SemiBold"
                                                                   FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding Note}"
                                                               Foreground="{DynamicResource Theme.TextBase}" FontSize="13"
                                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <!-- ══════════════════════════════════════════════════════
                         设置面板
                    ══════════════════════════════════════════════════════ -->
                    <StackPanel x:Name="PanelSettings" Visibility="Collapsed">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 左列 -->
                            <StackPanel Grid.Column="0">
                                <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Viewbox Width="15" Height="15" Margin="0,0,7,0" VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM12 7v5l3 3"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="专注与休息规则" FontSize="13" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI"/>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="工作周期" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="InpWorkInterval" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                                        <TextBlock Grid.Column="2" Text="分钟" Style="{StaticResource UnitStyle}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="休息时长" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="InpRestDuration" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                                        <TextBlock Grid.Column="2" Text="分钟" Style="{StaticResource UnitStyle}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="提前预警" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="InpWarningDuration" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                                        <TextBlock Grid.Column="2" Text="分钟" Style="{StaticResource UnitStyle}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="空闲重置" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="InpIdle" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                                        <TextBlock Grid.Column="2" Text="分钟" Style="{StaticResource UnitStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="日志保留" Style="{StaticResource LabelStyle}"/>
                                        <TextBox x:Name="InpMaxLogDays" Grid.Column="1" Style="{StaticResource ValueBoxStyle}"/>
                                        <TextBlock Grid.Column="2" Text="天" Style="{StaticResource UnitStyle}"/>
                                    </Grid>
                                </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14" Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="界面预览" FontSize="13" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource GhostBtn}" Content="预览预警" Click="BtnPreviewWarning_Click" Margin="0,0,8,0" Padding="12,6" FontSize="12"/>
                                            <Button Style="{StaticResource GhostBtn}" Content="预览微休息" Click="BtnPreviewMicro_Click" Padding="12,6" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 右列 -->
                            <StackPanel Grid.Column="2">
                                <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <Viewbox Width="15" Height="15" Margin="0,0,7,0" VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24"><Path Stroke="{DynamicResource Theme.Primary}" StrokeThickness="1.5" Fill="Transparent" Data="M10 22L14 2 12 11h8l-10 11 2-9H4l6-9z"/></Canvas>
                                            </Viewbox>
                                            <TextBlock Text="系统增强" FontSize="13" Foreground="{DynamicResource Theme.TextBase}" FontFamily="Segoe UI Semibold, Segoe UI, Microsoft YaHei UI"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkDnd" Content="智能免打扰 (全屏时推迟)" Margin="0,0,0,10" Foreground="{DynamicResource Theme.TextBase}" FontSize="12"/>
                                        <CheckBox x:Name="ChkMicroBreak" Content="20-20-20 微休息提示" Margin="0,0,0,10" Foreground="{DynamicResource Theme.TextBase}" FontSize="12"/>
                                        <CheckBox x:Name="ChkHealthTips" Content="休息界面显示健康贴士" Margin="0,0,0,10" Foreground="{DynamicResource Theme.TextBase}" FontSize="12"/>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <CheckBox x:Name="ChkHealthAlert" Content="健康评分过低时弹出强提醒" Foreground="{DynamicResource Theme.TextBase}" FontSize="12" VerticalAlignment="Center"/>
                                            <Button Style="{StaticResource GhostBtn}" Padding="4,2" Margin="4,0,0,0" ToolTip="点击了解详情" Click="BtnHealthAlertInfo_Click">
                                                <TextBlock Text="❓" FontSize="11" Foreground="{DynamicResource Theme.Primary}" VerticalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>

                                        <CheckBox x:Name="ChkStartup" Content="随系统启动" Margin="0,0,0,10" Foreground="{DynamicResource Theme.TextBase}" FontSize="12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="全局休息快捷键：" FontSize="12" Foreground="{DynamicResource Theme.TextBase}" VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                            <TextBox x:Name="InpShortcut" Grid.Column="1" Style="{StaticResource ValueBoxStyle}" ToolTip="立即触发休息的组合键 (如 Ctrl+Alt+R)"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="16">
                                    <StackPanel>
                                        <ComboBox x:Name="CmbBgStyle" Style="{StaticResource DarkComboStyle}" Margin="0,0,0,10">
                                            <ComboBoxItem Content="极限护眼模式"/>
                                            <ComboBoxItem Content="轻度毛玻璃"/>
                                            <ComboBoxItem Content="桌面毛玻璃"/>
                                        </ComboBox>
                                        <ComboBox x:Name="CmbAppTheme" Style="{StaticResource DarkComboStyle}">
                                            <ComboBoxItem Content="暗夜极客黑"/>
                                            <ComboBoxItem Content="冷翡高级灰"/>
                                            <ComboBoxItem Content="复古纸墨色"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                            <TextBlock x:Name="TxtSaveSuccess" Text="✓ 保存成功" Foreground="{DynamicResource Theme.Primary}" VerticalAlignment="Center" Margin="0,0,16,0" Visibility="Collapsed"/>
                            <Button Style="{StaticResource PrimaryBtn}" Click="BtnSave_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"
                                          Fill="{DynamicResource Theme.Bg}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                                    <TextBlock Text="保存配置" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- 关于面板 -->
                    <StackPanel x:Name="PanelAbout" Visibility="Collapsed">
                        <Border Background="{DynamicResource Theme.PanelBg}" CornerRadius="12" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Padding="24">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Image Source="/logo_hd.png" Width="48" Height="48" Margin="0,0,16,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="护眼卫士 · ProtectEye" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Theme.Primary}" FontFamily="Segoe UI Semibold, Microsoft YaHei UI"/>
                                        <TextBlock Text="{x:Static local:AppVersion.Version}" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="程序简介" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Theme.TextBase}" Margin="0,0,0,8"/>
                                <TextBlock Text="ProtectEye 是一款轻量级开源护眼工具，旨在通过科学的 20-20-20 法则和深度休息提醒，帮助长期使用电脑的用户缓解视疲劳，保护视力健康。" 
                                           Foreground="{DynamicResource Theme.TextDesc}" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="20"/>

                                <TextBlock Text="快速入门" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Theme.TextBase}" Margin="0,0,0,8"/>
                                <TextBlock Foreground="{DynamicResource Theme.TextDesc}" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="20">
