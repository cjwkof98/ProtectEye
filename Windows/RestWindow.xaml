<Window x:Class="ProtectEye.Windows.RestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="休息时间" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" 
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="RestBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMuted}"/>
            <Setter Property="Background" Value="{DynamicResource Theme.ControlBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="24,11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Theme.Sep}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Theme.TextBase}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PauseBtn" TargetType="Button" BasedOn="{StaticResource RestBtn}">
            <Setter Property="Foreground" Value="{DynamicResource Theme.PrimaryDark}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.PrimaryDark}"/>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainContainer" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <DoubleAnimation Storyboard.TargetName="ScaleMain" Storyboard.TargetProperty="ScaleX" From="0.95" To="1" Duration="0:0:1">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ScaleMain" Storyboard.TargetProperty="ScaleY" From="0.95" To="1" Duration="0:0:1">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="Aurora1Transform" Storyboard.TargetProperty="X" From="-400" To="400" Duration="0:0:20" />
                    <DoubleAnimation Storyboard.TargetName="Aurora1Transform" Storyboard.TargetProperty="Y" From="-200" To="300" Duration="0:0:25" />
                    <DoubleAnimation Storyboard.TargetName="Aurora2Transform" Storyboard.TargetProperty="X" From="200" To="-600" Duration="0:0:22" />
                    <DoubleAnimation Storyboard.TargetName="Aurora2Transform" Storyboard.TargetProperty="Y" From="500" To="-100" Duration="0:0:18" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="MainContainer" Opacity="0">
        <!-- 模糊背景（桌面截图毛玻璃模式时启用） -->
        <Border ClipToBounds="True">
            <Image x:Name="BgImage" Stretch="Fill" Margin="-100">
                <Image.Effect>
                    <BlurEffect Radius="60" KernelType="Gaussian"/>
                </Image.Effect>
            </Image>
        </Border>

        <!-- 遮罩层 -->
        <Border x:Name="MaskBorder" Background="{DynamicResource Theme.RestBg}"/>

        <!-- 极光呼吸层 -->
        <Canvas x:Name="AuroraCanvas" ClipToBounds="True" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- 霓虹青光球 -->
            <Ellipse Width="1800" Height="1500" Fill="{DynamicResource Theme.PrimaryDark}" Opacity="0.5" Margin="-900,-750,0,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="350" KernelType="Gaussian"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Aurora1Transform" X="0" Y="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <!-- 极夜蓝光球 -->
            <Ellipse Width="2200" Height="1600" Fill="{DynamicResource Theme.Aurora2}" Opacity="0.4" Margin="-1100,-800,0,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="400" KernelType="Gaussian"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Aurora2Transform" X="200" Y="300"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <!-- 细微纹理线（装饰） -->
        <Canvas Opacity="0.03">
            <Rectangle Fill="White" Width="2000" Height="1" Canvas.Top="300"/>
            <Rectangle Fill="White" Width="2000" Height="1" Canvas.Top="600"/>
            <Rectangle Fill="White" Width="2000" Height="1" Canvas.Top="900"/>
        </Canvas>

        <!-- 主内容区域 -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
            <StackPanel.RenderTransform>
                <ScaleTransform x:Name="ScaleMain" ScaleX="1" ScaleY="1" />
            </StackPanel.RenderTransform>

            <!-- 顶部 Teal 指示光点 -->
            <Ellipse Width="6" Height="6" Fill="{DynamicResource Theme.PrimaryDark}" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="{DynamicResource Theme.ShadowColor}" Opacity="0.8"/>
                </Ellipse.Effect>
            </Ellipse>

            <!-- 标题 -->
            <TextBlock Text="休息时间到" Foreground="{DynamicResource Theme.TextMuted}" FontSize="14" FontFamily="Segoe UI" 
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- 大倒计时 -->
            <TextBlock x:Name="TxtCountdown" Text="05:00" 
                       Foreground="{DynamicResource Theme.Primary}" FontSize="140" FontWeight="Bold"
                       FontFamily="Segoe UI Light, Segoe UI"
                       HorizontalAlignment="Center" Margin="0,0,0,8">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="{DynamicResource Theme.ShadowColor}" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- 实时时间 -->
            <TextBlock x:Name="TxtCurrentTime" Text="12:30:00" 
                       Foreground="{DynamicResource Theme.TextBase}" FontSize="16" FontWeight="Light"
                       FontFamily="Segoe UI Light, Segoe UI"
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <!-- 分隔线 -->
            <Rectangle Width="1" Height="40" Fill="{DynamicResource Theme.Sep}" HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- 古诗 / 金句 -->
            <TextBlock x:Name="TxtQuote" Text="长风破浪会有时，直挂云帆济沧海"
                       FontFamily="KaiTi, 楷体, STKaiti"
                       FontStyle="Italic"
                       Foreground="{DynamicResource Theme.TextBase}" FontSize="36"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center"
                       MaxWidth="600"
                       Margin="0,0,0,24"/>

            <!-- 健康护眼贴士 -->
            <TextBlock x:Name="TxtHealthTip" Text="💡 经常转动眼球，有助于放松眼部肌肉"
                       FontFamily="Segoe UI, Microsoft YaHei UI"
                       Foreground="{DynamicResource Theme.PrimaryDark}" FontSize="14" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,50" Visibility="Collapsed"/>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="跳过" Style="{StaticResource RestBtn}" Margin="0,0,10,0" Click="BtnSkip_Click"/>
                <Button Content="延长 1 分钟" Style="{StaticResource RestBtn}" Margin="0,0,10,0" Click="BtnExtend_Click"/>
                <Button x:Name="BtnPause" Content="暂停" Style="{StaticResource PauseBtn}" Click="BtnPause_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
