<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Natural Paper & Rust theme -->
    <SolidColorBrush x:Key="Theme.Bg" Color="#F5F2E9"/> <!-- Soft aged paper -->
    <SolidColorBrush x:Key="Theme.PanelBg" Color="#F5F2E9"/>
    <SolidColorBrush x:Key="Theme.CardBg" Color="#EBE7DD"/>
    
    <SolidColorBrush x:Key="Theme.Primary" Color="#C2410C"/> <!-- Rust Orange (Softer) -->
    <SolidColorBrush x:Key="Theme.PrimaryDark" Color="#9A3412"/>
    <SolidColorBrush x:Key="Theme.PrimaryLight" Color="#EA580C"/>
    <Color x:Key="Theme.PrimaryDarkColor">#9A3412</Color>
    <Color x:Key="Theme.ShadowColor">#20C2410C</Color>
    
    <SolidColorBrush x:Key="Theme.TextBase" Color="#2D2926"/> <!-- Warm Charcoal -->
    <SolidColorBrush x:Key="Theme.TextMuted" Color="#57534E"/>
    <SolidColorBrush x:Key="Theme.TextDesc" Color="#78716C"/>
    
    <SolidColorBrush x:Key="Theme.Border" Color="#D6D3D1"/>
    <SolidColorBrush x:Key="Theme.Sep" Color="#E7E5E4"/>
    
    <SolidColorBrush x:Key="Theme.ControlBg" Color="#E7E5E4"/>
    <SolidColorBrush x:Key="Theme.ControlHover" Color="#D6D3D1"/>
    
    <SolidColorBrush x:Key="Theme.Aurora1" Color="#D97706"/> 
    <SolidColorBrush x:Key="Theme.Aurora2" Color="#B45309"/> 
    <SolidColorBrush x:Key="Theme.RestBg" Color="#E2E2D5"/> <!-- Muted greenish-gray rest -->
</ResourceDictionary>
